; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="水晶傳說 Tale of Crystal"
config/description="GDevelop → Godot 遷移專案（見 ../CLAUDE.md）。CORE-1 骨架，玩法內容待 CORE/MOD 任務展開。"
run/main_scene="res://scenes/title/title.tscn"
config/features=PackedStringArray("4.7", "GL Compatibility")

[autoload]

ContentDB="*res://autoload/content_db.gd"
AudioManager="*res://autoload/audio_manager.gd"
GameState="*res://autoload/game_state.gd"
SceneRouter="*res://autoload/scene_router.gd"
DialogueSystem="*res://scripts/dialogue/dialogue_system.gd"
InputBridge="*res://autoload/input_bridge.gd"
SaveManager="*res://autoload/save_manager.gd"
DebugHooks="*res://tests/debug_hooks.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/window_width_override=1920
window/size/window_height_override=1080
window/stretch/mode="canvas_items"
window/handheld/orientation="landscape"

[editor_plugins]

enabled=PackedStringArray("res://addons/funplay_mcp/plugin.cfg", "res://addons/godot_mcp/plugin.cfg")

