"rate": 1.5
}]
description = "遊走在生死之間的術士。他驅使黑水晶之力，將無法安息的礦工喚為傀儡——鎮民咒他褻瀆亡者，卻無人知道，他這麼做只為換取一線治好垂危妹妹的可能。戰場上他總是先癒合同伴的傷，再冷眼看你倒下。"

[sub_resource type="Resource" id="Resource_cs8nw"]
script = ExtResource("4_hoq51")
id = "ogre"
display_name = "洞窟食人魔"
sprite = "ogre"
hp = 1600.0
atk = 38.0
def_stat = 18.0
spd = 6.0
luck = 4.0
exp = 400
gold = 350
big = true
all_attack = true
drops = [{
"id": "crystal_shard",
"rate": 16.0
}, {
"id": "beast_hide",
"rate": 2.5
}]
foe_skills = [{
"mult": 2.0,
"name": "巨槌重砸",
"target": "one"
}, {
"mult": 1.35,
"name": "崩山地裂",
"target": "all"
}]
description = "棲身礦坑最深處的龐然巨魔，據說是吞噬了大量水晶，才長成這副駭人的體格。牠揮舞的巨槌足以砸碎岩層，遲緩的身軀底下藏著毀天滅地的力量。膽敢深入母脈的人，牠是一道繞不過去的血肉高牆。"

[sub_resource type="Resource" id="Resource_f55ks"]
script = ExtResource("4_hoq51")
id = "shadow_demon"
display_name = "異變的魔影"
sprite = "demon"
hp = 9999.0
atk = 22.0
def_stat = 25.0
spd = 12.0
luck = 5.0
big = true
description = "序章在礦山深處現身的異形存在，連 A 級冒險者都擋不住。牠不屬於這片大地——沒有名字，沒有來歷，只有一股令人窒息的惡意，與近乎必然的壓迫感。牠不過是黑水晶背後那個更深沉威脅的一縷投影；真正的黑幕，還藏在更遠的地方。"

