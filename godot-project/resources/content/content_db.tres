[sub_resource type="Resource" id="Resource_pcq0f"]
script = ExtResource("8_j105i")
id = "ludo"
display_name = "路德"
char_class = "explorer"
main_attr = "str"
sprite = "ludo"
base = {
"agi": 3.0,
"int": 2.0,
"str": 4.0
}
growth = {
"agi": 1.0,
"int": 1.0,
"str": 2.0
}
start_eq = {
"armor": "traveler_garb",
"boots": "leather_boots",
"weapon": "short_sword",
"wrist": "cloth_wraps"
}
story = ["芳蕾鎮鐵匠漢克與瑪莎的獨生子，十五歲。", "從小聽著往來旅人的冒險故事長大，一心嚮往外面的世界，", "行動總是比思考快半拍，闖禍後道歉的速度倒是全鎮最快。", "十五歲那年，偷跟著借宿鎮上的冒險者亞倫進入北方礦山，", "在深處遭遇了不該存在的魔物——亞倫為掩護他而下落不明。", "「我要成為真正的冒險者，查出那一天的真相。」"]

[sub_resource type="Resource" id="Resource_s60oe"]
script = ExtResource("8_j105i")
id = "marin"
display_name = "瑪琳"
char_class = "explorer"
main_attr = "agi"
sprite = "marin"
base = {
"agi": 4.0,
"int": 3.0,
"str": 3.0
}
growth = {
"agi": 2.0,
"int": 1.0,
"str": 1.0
}
start_eq = {
"acc1": "agate_charm",
"armor": "traveler_garb",
"boots": "leather_boots",
"weapon": "hunting_knife"
}
story = ["旅店老闆娘朵拉的女兒，與路德一起長大的青梅竹馬。", "冷靜務實，是路德闖禍前的最後一道煞車——雖然常常煞不住。", "身手靈巧，一手獵刀是幫旅店處理野味時練出來的本事，", "戴著的瑪瑙護符，是母親朵拉在她出發前偷偷塞進行囊的。", "礦山意外後，看著把自己關在房裡的路德，她只說了一句：", "「要去就一起去。你一個人，我不放心。」"]

[sub_resource type="Resource" id="Resource_n1ogd"]
script = ExtResource("8_j105i")
id = "aaron"
display_name = "亞倫"
char_class = "veteran"
main_attr = "str"
sprite = "aaron"
base = {
"agi": 24.0,
"int": 14.0,
"str": 30.0
}
start_level = 20
start_eq = {
"armor": "leather_vest",
"boots": "swift_boots",
"weapon": "iron_sword",
"wrist": "iron_bracer"
}
story = ["借宿芳蕾鎮的 A 級冒險者。話少，劍快。", "來歷成謎，只知道他一直在調查北方礦山的異變。", "看出路德眼裡的光和「年輕時的某人」很像，", "嘴上嫌麻煩，卻默許了少年的跟隨。", "礦山深處遭遇異變魔影時，他擋在路德身前——", "「快跑！把這裡的事告訴鎮上的人！」", "此後下落不明。他留下的劍術與背影，成了路德的目標。"]
guest = true

