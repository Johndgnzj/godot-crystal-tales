[sub_resource type="Resource" id="Resource_v4bx3"]
script = ExtResource("4_hoq51")
id = "bird"
display_name = "掠翅鳥"
sprite = "bird"
hp = 28.0
atk = 7.0
def_stat = 2.0
spd = 14.0
exp = 5
gold = 3
drops = [{
"id": "soft_feather",
"rate": 1.2
}]
description = "成群掠過林梢的猛禽，俯衝時快得只剩一道殘影。單獨一隻不足為懼，偏偏牠們總愛呼朋引伴，等你回過神，肩上往往已經被啄了好幾口。羽毛輕軟，是縫製衣物的搶手貨。"

[sub_resource type="Resource" id="Resource_2d226"]
script = ExtResource("4_hoq51")
id = "gslime"
display_name = "綠黏史萊姆"
sprite = "gslime"
hp = 44.0
atk = 6.0
def_stat = 4.0
spd = 4.0
exp = 6
gold = 4
drops = [{
"id": "slime_gel",
"rate": 1.25
}]
description = "地脈魔力滲進水窪，日積月累就凝成這麼一坨會抖的綠色果凍。沒腦、沒骨，也沒什麼脾氣，唯一的戰術是「慢慢靠近再黏上去」——以牠的移動速度，這計畫多半在靠近你之前就先失敗了。黏液拿來熬膠意外好用。"

[sub_resource type="Resource" id="Resource_38aoo"]
script = ExtResource("4_hoq51")
id = "worm"
display_name = "巨牙蟲"
sprite = "worm"
hp = 34.0
atk = 11.0
def_stat = 3.0
spd = 7.0
exp = 8
gold = 5
drops = [{
"id": "worm_carapace",
"rate": 1.2
}]
description = "潛伏在鬆軟土層裡的環節巨蟲，平時只把顎牙探出地面。牠沒有眼睛，靠地面震動鎖定獵物，所以你的腳步越重，牠就越興奮。外殼硬得出奇，敲下來能湊合當塊護甲。"

[sub_resource type="Resource" id="Resource_1f648"]
script = ExtResource("4_hoq51")
id = "goblin"
display_name = "哥布林拾荒者"
sprite = "goblin"
hp = 38.0
atk = 9.0
def_stat = 4.0
spd = 8.0
exp = 8
gold = 7
drops = [{
"id": "goblin_fang",
"rate": 1.1
}]
description = "東之森一帶最常見的小型魔物，個頭不高、心眼不少。牠們不擅正面交鋒，專挑落單的旅人下手，得手就往草叢裡一鑽。與其說危險，不如說煩人——尤其當牠們成群結隊、又剛好看上你的行囊時。"

[sub_resource type="Resource" id="Resource_7ak06"]
script = ExtResource("4_hoq51")
id = "goblin_chief"
display_name = "哥布林頭目"
sprite = "maskedorc"
hp = 780.0
atk = 26.0
def_stat = 13.0
spd = 10.0
luck = 3.0
exp = 140
gold = 150
big = true
drops = [{
"id": "goblin_fang",
"rate": 5.0
}, {
"id": "crystal_shard",
"rate": 5.0
}]
foe_skills = [{
"mult": 1.9,
"name": "猛力連擊",
"target": "one"
}, {
"mult": 1.15,
"name": "亂舞橫掃",
"target": "all"
}]
description = "盤踞東之森深處的哥布林群首領，體格是尋常同類的兩三倍，一身劫掠來的雜甲彰顯著牠的地位。牠靠蠻力與狡詐坐穩王座，麾下嘍囉為牠賣命。想安然穿過這片森林，就得先讓這傢伙低頭。"

[sub_resource type="Resource" id="Resource_auvyr"]
script = ExtResource("4_hoq51")
id = "bear"
display_name = "洞熊"
sprite = "bear"
hp = 120.0
atk = 16.0
def_stat = 9.0
spd = 5.0
exp = 28
gold = 18
drops = [{
"id": "beast_hide",
"rate": 2.5
}]
description = "北方礦山一帶的野生巨獸，厚毛皮下是一身橫練的筋肉。平時窩在洞裡打盹，一旦地盤被闖入就翻臉不認熊。鎮上不少獵人栽在牠掌下——據說連某位未來的冒險者，小時候也曾被牠追著滿山跑。"

[sub_resource type="Resource" id="Resource_j7mbp"]
script = ExtResource("4_hoq51")
id = "bear_dire"
display_name = "狂暴洞熊"
sprite = "bear"
hp = 1200.0
atk = 36.0
def_stat = 16.0
spd = 8.0
luck = 3.0
exp = 180
gold = 100
big = true
all_attack = true
drops = [{
"id": "beast_hide",
"rate": 8.0
}, {
"id": "crystal_shard",
"rate": 6.0
}]
foe_skills = [{
"mult": 2.1,
"name": "狂亂撕咬",
"target": "one"
}, {
"mult": 1.25,
"name": "震地怒吼",
"target": "all"
}]
description = "原本只是尋常的洞熊，卻因長期浸在黑水晶的氣息裡而徹底失了心智。牠雙眼滲著不祥的微光，咆哮能震落洞頂的碎石，痛覺與恐懼再也拉不住牠。這已不是野獸的兇性，而是腐化留下的、無從安撫的狂亂。"

[sub_resource type="Resource" id="Resource_wykaa"]
script = ExtResource("4_hoq51")
id = "wolf"
display_name = "野狼"
sprite = "wolf"
hp = 68.0
atk = 13.0
def_stat = 6.0
spd = 12.0
exp = 16
gold = 11
drops = [{
"id": "wolf_hide",
"rate": 2.0
}, {
"id": "beast_hide",
"rate": 0.75
}]
description = "山林間的狩獵者，落單時謹慎，成群時卻膽大包天。牠們懂得包抄與輪番進攻，遇上落單旅人絕不客氣。老獵人說，聽見第一聲狼嚎就該拔腿了——那是呼喚同伴的信號。"

[sub_resource type="Resource" id="Resource_dfnc1"]
script = ExtResource("4_hoq51")
id = "wogol"
display_name = "礦坑飛魔"
sprite = "wogol"
hp = 40.0
atk = 11.0
def_stat = 4.0
spd = 15.0
exp = 11
gold = 8
drops = [{
"id": "crystal_shard",
"rate": 1.0
}]
description = "在礦坑深處竄飛的小型魔物，速度快得令人咋舌，總在火把照不到的暗角忽隱忽現。牠們受水晶微光吸引而聚集，體內積著一點碎晶——這也讓牠們成了礦道裡最難纏的小偷。"

[sub_resource type="Resource" id="Resource_sahc2"]
script = ExtResource("4_hoq51")
id = "skeleton"
display_name = "骷髏礦工"
sprite = "skeleton"
hp = 58.0
atk = 12.0
def_stat = 7.0
spd = 7.0
exp = 12
gold = 10
drops = [{
"id": "bone_shard",
"rate": 1.2
}, {
"id": "iron_ore",
"rate": 0.8
}]
description = "二十年前封礦時失蹤的礦工，如今提著鏽蝕的鎬，重新走回礦道。黑水晶奪走了他們的姓名與安息，只留下不斷挖掘的本能。有些骨手仍緊攥著當年沒能帶出去的礦石——他們，始終沒能下班。"

[sub_resource type="Resource" id="Resource_vjhig"]
script = ExtResource("4_hoq51")
id = "orc"
display_name = "獸人挖掘者"
sprite = "orc"
hp = 82.0
atk = 14.0
def_stat = 9.0
spd = 6.0
exp = 18
gold = 14
drops = [{
"id": "iron_ore",
"rate": 1.5
}, {
"id": "bone_shard",
"rate": 0.5
}]
description = "被驅使進礦坑挖掘的粗壯獸人，肌肉遠比腦子發達。揮起鎬來連岩壁都吃不消，更別提擋在中間的人。渾身沾滿鐵屑與礦渣，顯然這苦力活，牠們幹的不是一天兩天了。"

[sub_resource type="Resource" id="Resource_hnf0v"]
script = ExtResource("4_hoq51")
id = "chort"
display_name = "暗影小魔"
sprite = "chort"
hp = 50.0
atk = 14.0
def_stat = 5.0
spd = 13.0
exp = 16
gold = 12
drops = [{
"id": "crystal_shard",
"rate": 1.2
}]
description = "形體不定的小型暗影魔物，像從黑水晶的陰影裡滲出來的一團惡意。牠畏光，動作卻刁鑽，專趁人分神時撲上來抓一把。若在礦道裡撞見成群的牠們，意味著黑水晶的汙染已經不遠。"

[sub_resource type="Resource" id="Resource_1s8rn"]
