[sub_resource type="Resource" id="Resource_pcq0f"]
script = ExtResource("8_j105i")
id = "ludo"
display_name = "路德"
char_class = "explorer"
main_attr = "str"
sprite = "ludo"
base = {
"agi": 3.0,
"int": 2.0,
"luck": 2.0,
"str": 4.0
}
growth = {
"agi": 1.0,
"int": 1.0,
"str": 2.0
}
start_eq = {
"armor": "traveler_garb",
"boots": "leather_boots",
"weapon": "short_sword",
"wrist": "cloth_wraps"
}
story = ["芳蕾鎮一對退休冒險者——漢克與瑪莎——的兒子，十五歲，還有個小一歲的妹妹瑪琳。", "從小聽著父母當年闖蕩的冒險故事長大，一心嚮往外面的世界，", "行動總是比思考快半拍，闖禍後道歉的速度倒是全鎮最快。", "偷偷跟著借宿鎮上的冒險者亞倫進入北方礦山，", "在深處遭遇了不該存在的魔影——亞倫為掩護他而下落不明。", "身上的蓋婭女神記號，會隨著冒險一分分變亮。", "「我要成為真正的冒險者，查出那一天的真相。」"]

[sub_resource type="Resource" id="Resource_s60oe"]
script = ExtResource("8_j105i")
id = "marin"
display_name = "瑪琳"
char_class = "explorer"
main_attr = "agi"
sprite = "marin"
base = {
"agi": 4.0,
"int": 3.0,
"luck": 3.0,
"str": 3.0
}
growth = {
"agi": 2.0,
"int": 1.0,
"str": 1.0
}
start_eq = {
"acc1": "agate_charm",
"armor": "traveler_garb",
"boots": "leather_boots",
"weapon": "hunting_knife"
}
story = ["路德的妹妹，小他一歲，同為退休冒險者漢克與瑪莎之女。", "冷靜務實，是路德闖禍前的最後一道煞車——雖然常常煞不住。", "身手靈巧、主敏捷，關鍵時刻比誰都可靠。", "戴著的瑪瑙護符，是母親瑪莎在她出發前偷偷塞進行囊的。", "礦山意外後，看著把自己關在房裡的路德，她只說了一句：", "「要去就一起去。你一個人，我不放心。」"]

[sub_resource type="Resource" id="Resource_n1ogd"]
script = ExtResource("8_j105i")
id = "alan"
display_name = "亞倫"
char_class = "veteran"
main_attr = "str"
sprite = "alan"
base = {
"agi": 24.0,
"int": 14.0,
"luck": 8.0,
"str": 30.0
}
start_level = 35
start_eq = {
"armor": "leather_vest",
"boots": "swift_boots",
"weapon": "iron_sword",
"wrist": "iron_bracer"
}
story = ["借宿芳蕾鎮的資深冒險者，二十六歲。平時輕浮、吊兒郎當，遇到麻煩第一個想偷懶——但實力貨真價實。", "年輕當菜鳥時受過路德的退休冒險者父母照顧，欠他們一份人情，", "因此把這鎮上的少年當弟弟看，也默許了他的跟隨。", "接下公會「調查北方礦山」的委託才動身，路德偷偷跟了上去。", "礦山深處遭遇異變魔影時，這個最愛偷懶的人卻擋在路德身前——", "「快跑！把這裡的事回報公會！」", "此後下落不明。他留下的劍與背影，成了路德的目標。"]
guest = true

