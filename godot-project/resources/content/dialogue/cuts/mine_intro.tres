[gd_resource type="Resource" script_class="CutsceneEntry" format=3]

[ext_resource type="Script" path="res://scripts/dialogue/cutscene_line.gd" id="1_dwynv"]
[ext_resource type="Script" path="res://scripts/dialogue/cutscene_entry.gd" id="2_3t1ji"]

[sub_resource type="Resource" id="Resource_aopkl"]
script = ExtResource("1_dwynv")
speaker = "亞倫"
text = "跟緊我，路德。礦山不是給小孩玩的地方。"

[sub_resource type="Resource" id="Resource_v50dc"]
script = ExtResource("1_dwynv")
speaker = "路德"
text = "我、我才不是小孩！我十五歲了！"

[sub_resource type="Resource" id="Resource_8bry5"]
script = ExtResource("1_dwynv")
speaker = "亞倫"
text = "……哼。前面的碎石地會竄出魔物，正好給你練練手。"

[sub_resource type="Resource" id="Resource_8phi5"]
script = ExtResource("1_dwynv")
text = "（教學：走進碎石地會遭遇戰鬥。方向鍵移動，往北邊的礦坑口前進）"

[resource]
