[gd_resource type="Resource" script_class="CutsceneEntry" format=3]

[ext_resource type="Script" path="res://scripts/dialogue/cutscene_line.gd" id="1_nec_l"]
[ext_resource type="Script" path="res://scripts/dialogue/cutscene_entry.gd" id="2_nec_e"]

[sub_resource type="Resource" id="Resource_nec1"]
script = ExtResource("1_nec_l")
text = "（礦道深處，骷髏礦工的殘骸環繞著一塊搏動的黑水晶。一個黑袍身影背對著眾人低語。）"

[sub_resource type="Resource" id="Resource_nec2"]
script = ExtResource("1_nec_l")
speaker = "死靈術士"
text = "……別過來。這裡不是你們該踏進的地方。"

[sub_resource type="Resource" id="Resource_nec3"]
script = ExtResource("1_nec_l")
speaker = "路德"
text = "這些礦工……是你把他們變成這樣的嗎！"

[sub_resource type="Resource" id="Resource_nec4"]
script = ExtResource("1_nec_l")
speaker = "死靈術士"
text = "我只是需要這水晶的力量。為了……不，跟你們說也沒用。"

[sub_resource type="Resource" id="Resource_nec5"]
script = ExtResource("1_nec_l")
speaker = "死靈術士"
text = "擋路的話——就別怪我手下無情了。"

[resource]
script = ExtResource("2_nec_e")
id = "necro_intro"
once = "c_necro_intro"
lines = Array[ExtResource("1_nec_l")]([SubResource("Resource_nec1"), SubResource("Resource_nec2"), SubResource("Resource_nec3"), SubResource("Resource_nec4"), SubResource("Resource_nec5")])
