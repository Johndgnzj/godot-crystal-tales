[gd_resource type="Resource" script_class="CutsceneEntry" format=3]

[ext_resource type="Script" path="res://scripts/dialogue/cutscene_line.gd" id="1_line"]
[ext_resource type="Script" path="res://scripts/dialogue/cutscene_entry.gd" id="2_entry"]

[sub_resource type="Resource" id="L1"]
script = ExtResource("1_line")
speaker = ""
text = "亞倫的劍壓不住那東西。他單膝跪地，撐著劍回頭。"

[sub_resource type="Resource" id="L2"]
script = ExtResource("1_line")
speaker = "亞倫"
text = "——還愣著幹嘛！叫你跑！"

[sub_resource type="Resource" id="L3"]
script = ExtResource("1_line")
speaker = "路德"
text = "我不能丟下你——！"

[sub_resource type="Resource" id="L4"]
script = ExtResource("1_line")
speaker = "亞倫"
text = "（難得認真地笑了一下）傻小子。回鎮上，把這裡的事回報公會——這是大哥給你的最後一個委託。快去！"

[sub_resource type="Resource" id="L5"]
script = ExtResource("1_line")
speaker = ""
text = "（路德被一股力量推開，踉蹌往外跑。身後金鐵交擊、那東西的咆哮，然後——歸於死寂。）"

[sub_resource type="Resource" id="L6"]
script = ExtResource("1_line")
speaker = ""
text = "——三天後，芳蕾鎮。"

[resource]
script = ExtResource("2_entry")
id = "s3_alan_fall"
once = "c_s3_alan_fall"
lines = Array[ExtResource("1_line")]([SubResource("L1"), SubResource("L2"), SubResource("L3"), SubResource("L4"), SubResource("L5"), SubResource("L6")])
transfer = PackedStringArray("Town", "home")
setstep = 7
party = PackedStringArray("ludo")
