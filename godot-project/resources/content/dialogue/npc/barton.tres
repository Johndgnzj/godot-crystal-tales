[gd_resource type="Resource" script_class="NpcDialogue" format=3]

[ext_resource type="Script" path="res://scripts/dialogue/dialogue_entry.gd" id="1_dm2me"]
[ext_resource type="Script" path="res://scripts/dialogue/npc_dialogue.gd" id="2_djpd7"]

[sub_resource type="Resource" id="Resource_xeui8"]
script = ExtResource("1_dm2me")
when = "ch2>=3"
speaker = "巴頓鎮長"
lines = PackedStringArray("礦工失蹤的事……我早該多過問一句的。", "孩子，你們比這鎮上所有大人都勇敢。", "把礦山看到的一切，原原本本告訴大城的人吧。")
cmd = "talk"

[sub_resource type="Resource" id="Resource_tcj3b"]
script = ExtResource("1_dm2me")
when = "ch1==3"
speaker = "巴頓鎮長"
lines = PackedStringArray("哥布林的事多虧你們了。", "但礦山的異變……我總覺得沒那麼簡單。")
cmd = "talk"

[sub_resource type="Resource" id="Resource_jolwk"]
script = ExtResource("1_dm2me")
when = "ch1_step==0"
speaker = "巴頓鎮長"
lines = PackedStringArray("聽說亞倫先生要帶你去礦山見習？", "好好跟著學，別亂跑。")
cmd = "talk"

[sub_resource type="Resource" id="Resource_6l0j3"]
script = ExtResource("1_dm2me")
speaker = "巴頓鎮長"
lines = PackedStringArray("礦山最近不太平靜，連老獵人都不敢靠近。", "亞倫先生的事……我很遺憾。孩子，別勉強自己。")
cmd = "talk"

[resource]
script = ExtResource("2_djpd7")
id = "barton"
entries = Array[ExtResource("1_dm2me")]([SubResource("Resource_xeui8"), SubResource("Resource_tcj3b"), SubResource("Resource_jolwk"), SubResource("Resource_6l0j3")])
