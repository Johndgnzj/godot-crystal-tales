[gd_resource type="Resource" script_class="NpcDialogue" format=3]

[ext_resource type="Script" path="res://scripts/dialogue/dialogue_entry.gd" id="1_gray_e"]
[ext_resource type="Script" path="res://scripts/dialogue/npc_dialogue.gd" id="2_gray_n"]

[sub_resource type="Resource" id="thanks"]
script = ExtResource("1_gray_e")
when = "ch1_step>=12"
speaker = "老葛雷"
lines = PackedStringArray("那些孩子……總算能讓我有個交代了。", "深處那股邪氣的源頭，就拜託你們了。萬事小心。")
cmd = "talk"

[sub_resource type="Resource" id="remind"]
script = ExtResource("1_gray_e")
when = "ch1_step>=10"
speaker = "老葛雷"
lines = PackedStringArray("那守衛啊，就好一口酒。", "聽說東之森東邊 f 區有棵老樹，樹上的『烈火蜂蜜』最對味——採回來交給道具店的吉德，他自有辦法。")
cmd = "talk"

[sub_resource type="Resource" id="request"]
script = ExtResource("1_gray_e")
when = "ch1_step==9"
speaker = "老葛雷"
lines = PackedStringArray("（叼著菸斗打量兩人）公會派來的新人？也罷。", "礦坑裡失蹤的，是跟我一起挖了半輩子的老夥伴。官府當他們逃工，不管。", "可我知道——他們絕不會丟下家人不告而別。你們要是有辦法進去，幫我看看他們……到底怎麼了。", "【委託】設法進入被封鎖的北方礦山。拜託了。")
action = "s5_start"
cmd = "talk"

[sub_resource type="Resource" id="generic"]
script = ExtResource("1_gray_e")
speaker = "老葛雷"
lines = PackedStringArray("那礦坑二十年前就封了……最近夜裡卻有聲音。", "唉，可憐的亞倫先生。")
cmd = "talk"

[resource]
script = ExtResource("2_gray_n")
id = "gray"
entries = Array[ExtResource("1_gray_e")]([SubResource("thanks"), SubResource("remind"), SubResource("request"), SubResource("generic")])
