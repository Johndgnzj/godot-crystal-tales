[gd_resource type="Resource" script_class="NpcDialogue" format=3]

[ext_resource type="Script" path="res://scripts/dialogue/dialogue_entry.gd" id="1_x51ct"]
[ext_resource type="Script" path="res://scripts/dialogue/npc_dialogue.gd" id="2_ly16l"]

[sub_resource type="Resource" id="Resource_post"]
script = ExtResource("1_x51ct")
when = "gotSword==1"
speaker = "漢克"
lines = PackedStringArray("該跑的時候就跑，別逞強。", "……那把劍陪過我不少險路，也讓它護著你。")
cmd = "talk"

[sub_resource type="Resource" id="Resource_gift"]
script = ExtResource("1_x51ct")
when = "ch1_step>=3"
speaker = "漢克"
lines = PackedStringArray("……路德，你也要出去闖了啊。", "（取下牆上一把用舊的劍）拿去。這把陪我走過不少地方。別死在外面。", "（獲得『漢克的舊劍』！開啟 選單→裝備 分頁換上它）")
action = "give_sword"
cmd = "hank_gift"
label = "臨別贈言"
done = "gotSword"

[sub_resource type="Resource" id="Resource_talk"]
script = ExtResource("1_x51ct")
speaker = "漢克"
lines = PackedStringArray("冒險者？哼，那可不是鬧著玩的。", "……你亞倫大哥那麼強的人都能出事。別走我們的老路。")
cmd = "talk"

[resource]
script = ExtResource("2_ly16l")
id = "hank"
entries = Array[ExtResource("1_x51ct")]([SubResource("Resource_post"), SubResource("Resource_gift"), SubResource("Resource_talk")])
