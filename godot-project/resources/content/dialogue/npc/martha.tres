script = ExtResource("1_b7qdl")
speaker = "瑪莎"
lines = PackedStringArray("你這孩子，越來越像年輕時的你爸了。", "這枚戒指你戴著——是我年輕時你爸打的，保平安。", "（獲得『活力戒指』！開啟 選單→裝備 可以裝上）")
