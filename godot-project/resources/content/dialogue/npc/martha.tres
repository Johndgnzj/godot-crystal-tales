label = "母親的心意"
done = "gotRing"

[sub_resource type="Resource" id="Resource_hvfht"]
script = ExtResource("1_b7qdl")
speaker = "瑪莎"
lines = PackedStringArray("你這孩子，越來越像年輕時的你爸了。", "路上一定要吃飽穿暖，聽到沒？")
