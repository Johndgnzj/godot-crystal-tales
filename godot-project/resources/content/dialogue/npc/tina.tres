[gd_resource type="Resource" script_class="NpcDialogue" format=3]

[ext_resource type="Script" path="res://scripts/dialogue/dialogue_entry.gd" id="1_tina_e"]
[ext_resource type="Script" path="res://scripts/dialogue/npc_dialogue.gd" id="2_tina_n"]

[sub_resource type="Resource" id="care"]
script = ExtResource("1_tina_e")
when = "ch1_step>=12"
speaker = "緹娜"
lines = PackedStringArray("礦坑深處的事……公會這邊也一直很掛心。", "小心點，別逞強——活著回來，才是好冒險者。")
cmd = "talk"

[sub_resource type="Resource" id="board"]
script = ExtResource("1_tina_e")
when = "reg==1"
speaker = "緹娜"
lines = PackedStringArray("委託都貼在牆上的告示板，慢慢看。", "東之森的採藥（找米拉）、討伐取證、還有鎮上的耳語——先從小的練練手。", "想找正經活兒的話，水井旁的老葛雷一直在找人幫忙，去聽聽他怎麼說。")
cmd = "quest"
label = "委託"

[sub_resource type="Resource" id="reg_do"]
script = ExtResource("1_tina_e")
when = "ch1_step>=8"
speaker = "緹娜"
lines = PackedStringArray("要登錄成為冒險者嗎？", "（端詳片刻，嘆氣又微笑）你們的爸媽當年，也是在這張桌子前登錄的。", "……路德、瑪琳，登錄完成！從今天起，你們就是 F 級冒險者了。", "（獲得『冒險者靴』！新人的裝備——路上小心，活著回來。）")
action = "register"
cmd = "quest"
label = "委託"

[sub_resource type="Resource" id="see"]
script = ExtResource("1_tina_e")
when = "ch1_step==0"
speaker = "緹娜"
lines = PackedStringArray("這不是路德嗎？要跟亞倫先生去礦山見習？", "等你正式登錄的那天，公會隨時歡迎你。")
cmd = "talk"

[sub_resource type="Resource" id="generic"]
script = ExtResource("1_tina_e")
speaker = "緹娜"
lines = PackedStringArray("委託都貼在牆上的告示板，慢慢看。", "有什麼想問的，儘管來櫃檯找我。")
cmd = "talk"

[resource]
script = ExtResource("2_tina_n")
id = "tina"
entries = Array[ExtResource("1_tina_e")]([SubResource("care"), SubResource("board"), SubResource("reg_do"), SubResource("see"), SubResource("generic")])
