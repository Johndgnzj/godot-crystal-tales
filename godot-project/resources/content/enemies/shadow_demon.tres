[ext_resource type="Script" path="res://scripts/content/enemy_def.gd" id="1_bom7n"]

[resource]
script = ExtResource("1_bom7n")
id = "shadow_demon"
display_name = "異變的魔影"
sprite = "demon"
hp = 9999.0
atk = 22.0
def_stat = 25.0
spd = 12.0
big = true
description = "序章在礦山深處現身的異形存在，連 A 級冒險者都擋不住。牠不屬於這片大地——沒有名字，沒有來歷，只有一股令人窒息的惡意，與近乎必然的壓迫感。牠不過是黑水晶背後那個更深沉威脅的一縷投影；真正的黑幕，還藏在更遠的地方。"
